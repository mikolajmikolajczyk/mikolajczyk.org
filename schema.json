{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mikolajczyk.org/schema/projects.json",
  "title": "Projects feed",
  "type": "object",
  "required": ["version", "projects"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version. Bump on breaking changes so the front can adapt."
    },
    "site": {
      "type": "object",
      "additionalProperties": false,
      "description": "Editable page texts (header, bio, footer).",
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "role": { "type": "string", "maxLength": 200 },
        "cfAnalytics": { "type": "string", "maxLength": 120,
                         "description": "Cloudflare Web Analytics beacon token. Injected into the front at build time." },
        "bio":  { "type": "array", "items": { "type": "string", "maxLength": 800 }, "maxItems": 6 },
        "footer": {
          "type": "array", "maxItems": 8,
          "items": {
            "type": "object",
            "required": ["label", "href"],
            "additionalProperties": false,
            "properties": {
              "label": { "type": "string", "minLength": 1, "maxLength": 40 },
              "href":  { "type": "string", "format": "uri" }
            }
          }
        }
      }
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/project" }
    },
    "posts": {
      "type": "array",
      "description": "Loose standalone posts (notes / microblog), shown in their own column.",
      "items": { "$ref": "#/$defs/post" }
    }
  },
  "$defs": {
    "project": {
      "type": "object",
      "required": ["id", "name", "year", "status", "descHtml", "chips", "shots", "worklog"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "minLength": 1,
          "maxLength": 64,
          "description": "Slug used in the deep-link (#/projekt/<id>). Lowercase, digits, hyphens."
        },
        "name":    { "type": "string", "minLength": 1, "maxLength": 120 },
        "year":    { "type": "integer", "minimum": 1990, "maximum": 2100 },
        "status":  { "type": "string", "enum": ["active", "done", "paused"] },
        "descHtml":{ "type": "string", "minLength": 1, "maxLength": 1200,
                     "description": "Short summary. Limited inline HTML (<b>) allowed; sanitize on render." },
        "chips":   { "type": "array", "maxItems": 8,
                     "items": { "type": "string", "minLength": 1, "maxLength": 40 } },
        "github":  { "type": ["string", "null"], "format": "uri" },
        "site":    { "type": ["string", "null"], "format": "uri" },
        "shots":   { "type": "array", "maxItems": 12, "items": { "$ref": "#/$defs/shot" } },
        "worklog": { "type": "array", "items": { "$ref": "#/$defs/entry" } }
      }
    },
    "shot": {
      "type": "object",
      "oneOf": [
        {
          "required": ["src"],
          "additionalProperties": false,
          "properties": {
            "src":   { "type": "string", "minLength": 1 },
            "alt":   { "type": "string", "maxLength": 200 },
            "badge": { "type": "string", "maxLength": 24 }
          }
        },
        {
          "required": ["placeholder"],
          "additionalProperties": false,
          "properties": {
            "placeholder": { "type": "string", "minLength": 1,
                             "description": "Filename label shown until a real screenshot replaces it." }
          }
        }
      ]
    },
    "post": {
      "type": "object",
      "required": ["id", "date", "md"],
      "additionalProperties": false,
      "properties": {
        "id":    { "type": "string", "pattern": "^[a-z0-9-]+$", "minLength": 1, "maxLength": 64,
                   "description": "Slug used in the deep-link (#/post/<id>). Lowercase, digits, hyphens." },
        "date":  { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2})?(-[0-9]{2})?$",
                   "description": "YYYY, YYYY-MM, or YYYY-MM-DD." },
        "title": { "type": "string", "maxLength": 160,
                   "description": "Optional heading. Omit for a microblog-style note." },
        "published": { "type": "boolean",
                   "description": "false = draft: hidden from the site, feed, RSS and search (still kept in projects.json)." },
        "md":    { "type": "string", "minLength": 1, "maxLength": 8000,
                   "description": "Markdown body. Rendered client-side." }
      }
    },
    "entry": {
      "type": "object",
      "required": ["kind", "ver", "date", "md"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["release", "note"] },
        "ver":  { "type": "string", "minLength": 1, "maxLength": 80,
                  "description": "Version tag (v0.18.0) or a note heading (Why I'm doing this)." },
        "date": { "type": "string", "pattern": "^[0-9]{4}(-[0-9]{2})?(-[0-9]{2})?$",
                  "description": "YYYY, YYYY-MM, or YYYY-MM-DD." },
        "md":   { "type": "string", "minLength": 1, "maxLength": 8000,
                  "description": "Markdown body. Rendered client-side." },
        "pinned": { "type": "boolean",
                  "description": "Pin to the top of the worklog, above the date-sorted entries." },
        "feed": { "type": "boolean",
                  "description": "Set false to hide this entry from the home feed (still shown on the project)." }
      }
    }
  }
}
